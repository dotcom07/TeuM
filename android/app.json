{
  "expo": {
    "name": "틈새움 TeuM",
    "slug": "teum",
    "scheme": "teum",
    "version": "0.1.0",
    "icon": "./assets/teum-logo.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.teum.app",
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_FULL_SCREEN_INTENT"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/teum-logo.png",
        "backgroundColor": "#7a8aba"
      }
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-notifications"
    ],
    "splash": {
      "backgroundColor": "#7a8aba"
    }
  }
}
