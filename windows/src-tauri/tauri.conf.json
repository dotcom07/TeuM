{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TeuM",
  "version": "0.1.0",
  "identifier": "com.teum.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "틈새움 TeuM",
        "width": 840,
        "height": 680,
        "minWidth": 760,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/teum-logo-rgba.png"]
  }
}
